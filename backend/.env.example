# Copy to .env for local dev; on Railway set these as service variables instead.

# PostgreSQL connection string (Railway provides this for the Postgres plugin)
DATABASE_URL=

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=

# External API keys
GEMINI_API_KEY=
RAWG_API_KEY=
TAVILY_API_KEY=
ITAD_API_KEY=

# Comma-separated emails allowed to trigger the chat "rootmode" debug cheat
DEVELOPER_EMAILS=

# Optional — Railway injects PORT automatically; defaults to 3000 locally
PORT=3000
