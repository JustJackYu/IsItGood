// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int              @id @default(autoincrement())
  email          String           @unique
  username       String?
  password       String
  createdAt      DateTime         @default(now())
  savedGames     SavedGame[]
  preferences    UserPreferences?
  summaryCaches  SummaryCache[]
}

// Per-user cached AI summary for a game (personalized by the user's preferences).
// Reused for up to an hour; `createdAt` is reset on regeneration.
model SummaryCache {
  id        Int      @id @default(autoincrement())
  userId    Int
  rawgId    Int
  summary   String
  sources   String[] @default([])
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, rawgId])
}

model UserPreferences {
  id                 Int           @id @default(autoincrement())
  userId             Int           @unique
  summaryLength      SummaryLength @default(MEDIUM)
  tone               Tone          @default(BALANCED)
  lookOutFor         String[]      @default([])
  allowMatureContent Boolean       @default(false)
  fontSize           FontSize      @default(MEDIUM)
  dealDisplay        DealDisplay   @default(BOTH)
  saleAlertDiscount  Int?
  saleAlertPrice     Float?
  updatedAt          DateTime      @updatedAt
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SummaryLength {
  SHORT
  MEDIUM
  LONG
}

enum Tone {
  CASUAL
  BALANCED
  CRITICAL
  ENTHUSIASTIC
}

enum FontSize {
  SMALL
  MEDIUM
  LARGE
}

enum DealDisplay {
  PRICE
  DISCOUNT
  BOTH
}

model SavedGame {
  id         Int      @id @default(autoincrement())
  userId     Int
  rawgId     Int
  title      String
  coverImage String?
  rating     Float?
  released   String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, rawgId])
}